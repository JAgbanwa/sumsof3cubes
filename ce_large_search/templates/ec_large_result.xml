<!--
  BOINC result template  —  ec_large search
  File:  templates/ec_large_result.xml
  Place in: $BOINC_PROJECT_DIR/templates/ec_large_result.xml
-->
<output_template>
    <file_info>
        <name><OUTFILE_0/></name>
        <generated_locally/>
        <upload_when_present/>
        <max_nbytes>104857600</max_nbytes>  <!-- 100 MB limit -->
        <url><UPLOAD_URL/></url>
    </file_info>
    <result>
        <file_ref>
            <file_number>0</file_number>
            <open_name>result.txt</open_name>
        </file_ref>
    </result>
</output_template>
